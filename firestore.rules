rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Profil utilisateur — MAIS le statut d'abonnement (plan, quota, isPro...)
    // ne doit JAMAIS être modifiable par le client : seul le backend
    // (webhook Stripe via Admin SDK, qui ignore ces règles de toute façon)
    // doit pouvoir l'écrire. Sinon n'importe qui peut se passer Pro gratuit
    // en éditant son propre document Firestore.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('plan' in request.resource.data) || request.resource.data.plan == 'trial')
        && !request.resource.data.keys().hasAny(['isPro', 'quotaJournalier', 'subscriptionStatus', 'stripeCustomerId']);
      allow update: if request.auth != null && request.auth.uid == userId
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['plan', 'isPro', 'quotaJournalier', 'subscriptionStatus', 'stripeCustomerId']);
      allow delete: if request.auth != null && request.auth.uid == userId;
      
      match /projects/{projectId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /missions/{missionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /memory/{memoryId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Public templates (store)
    match /public_templates/{templateId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update: if request.auth != null && resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
    }
    
    // Public profiles (community)
    match /public_profiles/{profileId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == profileId;
    }
  }
}
